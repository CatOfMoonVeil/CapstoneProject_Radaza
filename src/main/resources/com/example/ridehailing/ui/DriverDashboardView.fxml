<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ridehailing.ui.DriverDashboardController" prefWidth="450.0" prefHeight="550.0"
      style="-fx-background-color: #1e272e;">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label text="GoRide Driver Terminal" textFill="#10ac84">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>
        <Label fx:id="driverWelcomeLabel" text="Welcome, Driver" textFill="#84817a">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>
    </VBox>

    <VBox spacing="10.0" style="-fx-background-color: #2f3640; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/>
        </padding>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Vehicle Registered:" textFill="#84817a" style="-fx-font-weight: bold;"/>
            <Label fx:id="vehicleLabel" text="Retrieving details..." textFill="#dcdde1"/>
        </HBox>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="System Status:" textFill="#84817a" style="-fx-font-weight: bold;"/>
            <Label fx:id="statusLabel" text="ONLINE - Available" textFill="#10ac84" style="-fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
        <Label text="Driver Console Output" textFill="#dcdde1" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
        <TextArea fx:id="driverLogs" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                  style="-fx-control-inner-background: #2f3640; -fx-text-fill: #10ac84; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-background-color: #2f3640;"/>
    </VBox>

    <HBox spacing="15.0" alignment="CENTER">
        <Button fx:id="toggleAvailabilityButton" text="GO OFFLINE" onAction="#handleToggleAvailability" prefWidth="180.0" prefHeight="40.0"
                style="-fx-background-color: #ff4757; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-cursor: hand;"/>
        <Button text="LOG OUT" onAction="#handleLogOut" prefWidth="180.0" prefHeight="40.0"
                style="-fx-background-color: #718093; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-cursor: hand;"/>
    </HBox>
</VBox>