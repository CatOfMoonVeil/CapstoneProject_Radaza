<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ridehailing.ui.SignUpController" prefWidth="450.0" prefHeight="550.0"
      style="-fx-background-color: #1e272e;">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <Label text="Create Account" textFill="#00d2d3">
        <font>
            <Font name="System Bold" size="26.0" />
        </font>
    </Label>

    <VBox spacing="12.0" style="-fx-background-color: #2f3640; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <VBox spacing="4.0" alignment="CENTER_LEFT">
            <Label text="Full Name" textFill="#dcdde1" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
            <TextField fx:id="nameField" promptText="Your name" prefHeight="35.0"
                       style="-fx-background-color: #718093; -fx-text-fill: white; -fx-prompt-text-fill: #b2bec3; -fx-background-radius: 6px;"/>
        </VBox>

        <VBox spacing="4.0" alignment="CENTER_LEFT">
            <Label text="Phone Number" textFill="#dcdde1" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
            <TextField fx:id="phoneField" promptText="e.g. 09123456789" prefHeight="35.0"
                       style="-fx-background-color: #718093; -fx-text-fill: white; -fx-prompt-text-fill: #b2bec3; -fx-background-radius: 6px;"/>
        </VBox>

        <VBox spacing="4.0" alignment="CENTER_LEFT">
            <Label text="Email Address (Will be your login username)" textFill="#dcdde1" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
            <TextField fx:id="emailField" promptText="e.g. name@email.com" prefHeight="35.0"
                       style="-fx-background-color: #718093; -fx-text-fill: white; -fx-prompt-text-fill: #b2bec3; -fx-background-radius: 6px;"/>
        </VBox>
    </VBox>

    <VBox alignment="CENTER" spacing="12.0">
        <Button fx:id="signUpButton" text="REGISTER &amp; GO TO LOGIN" onAction="#handleSignUp" prefWidth="240.0" prefHeight="40.0"
                style="-fx-background-color: #10ac84; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 20px; -fx-cursor: hand;"/>

        <Button text="Back to Login" onAction="#handleBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: #00d2d3; -fx-underline: true; -fx-cursor: hand;"/>

        <Label fx:id="statusLabel" textFill="#ff4757" style="-fx-font-weight: bold; -fx-font-size: 12px;" wrapText="true" alignment="CENTER"/>
    </VBox>
</VBox>