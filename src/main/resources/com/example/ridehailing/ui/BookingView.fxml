<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ridehailing.ui.BookingController" prefWidth="450.0" prefHeight="550.0"
      style="-fx-background-color: #1e272e;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" prefHeight="40.0">
        <Label text="Dispatch Terminal" textFill="#ffffff">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>
    </HBox>

    <VBox spacing="15.0" style="-fx-background-color: #2f3640; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 8, 0, 0, 4);">
        <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="20.0"/>
        </padding>

        <VBox spacing="6.0" alignment="CENTER_LEFT">
            <Label text="PICKUP LOCATION" textFill="#00d2d3" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;" />
            <TextField fx:id="pickupField" promptText="Where should the driver pick you up?" prefHeight="38.0"
                       style="-fx-background-color: #3d3d3d; -fx-text-fill: white; -fx-prompt-text-fill: #718093; -fx-background-radius: 6px; -fx-border-color: #718093; -fx-border-radius: 6px;"/>
        </VBox>

        <VBox spacing="6.0" alignment="CENTER_LEFT">
            <Label text="DROP-OFF DESTINATION" textFill="#00d2d3" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;" />
            <TextField fx:id="destinationField" promptText="Enter destination endpoint..." prefHeight="38.0"
                       style="-fx-background-color: #3d3d3d; -fx-text-fill: white; -fx-prompt-text-fill: #718093; -fx-background-radius: 6px; -fx-border-color: #718093; -fx-border-radius: 6px;"/>
        </VBox>

        <HBox spacing="12.0" alignment="CENTER" prefHeight="45.0">
            <Button fx:id="bookButton" text="Request Ride" onAction="#handleBookRide" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="38.0"
                    style="-fx-background-color: #10ac84; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;"/>
            <Button fx:id="cancelButton" text="Abort" onAction="#handleCancelRide" disable="true" prefWidth="100.0" prefHeight="38.0"
                    style="-fx-background-color: #ee5253; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <VBox spacing="8.0" alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
        <Label text="LIVE SYSTEM MONITOR" textFill="#84817a" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
        <TextArea fx:id="statusLogs" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
                  style="-fx-control-inner-background: #2f3640; -fx-text-fill: #00ff00; -fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 12px; -fx-background-radius: 8px; -fx-border-color: #718093; -fx-border-radius: 8px;"/>
    </VBox>
</VBox>