<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ridehailing.ui.BookingController" prefWidth="450.0" prefHeight="550.0"
      style="-fx-background-color: #f8f9fa;">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="25.0"/>
    </padding>

    <Label text="Ride Request Terminal" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <VBox spacing="6.0" alignment="CENTER_LEFT">
        <Label text="Pickup Reference Point:" textFill="#34495e" style="-fx-font-weight: bold;" />
        <TextField fx:id="pickupField" promptText="e.g. Cebu IT Park, Tower 3" prefHeight="35.0"/>
    </VBox>

    <VBox spacing="6.0" alignment="CENTER_LEFT">
        <Label text="Target Destination:" textFill="#34495e" style="-fx-font-weight: bold;" />
        <TextField fx:id="destinationField" promptText="e.g. SM Seaside City" prefHeight="35.0"/>
    </VBox>

    <HBox spacing="15.0" alignment="CENTER" prefHeight="50.0">
        <Button fx:id="bookButton" text="Confirm &amp; Request" onAction="#handleBookRide" prefWidth="180.0" prefHeight="35.0"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="cancelButton" text="Abort Request" onAction="#handleCancelRide" disable="true" prefWidth="180.0" prefHeight="35.0"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <VBox spacing="6.0" alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
        <Label text="Platform Transaction History Pipeline:" textFill="#34495e" style="-fx-font-weight: bold;" />
        <TextArea fx:id="statusLogs" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
                  style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;"/>
    </VBox>
</VBox>